# ─────────────────────────────────────────────────────────────────────────────
# .env.example
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — add it to .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── WalletConnect ─────────────────────────────────────────────────────────────
# Free project ID from https://cloud.walletconnect.com
# Required for WalletConnect v2 (used by RainbowKit)
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# ── Pinata (IPFS) ─────────────────────────────────────────────────────────────
# Free JWT from https://app.pinata.cloud  (1 GB free storage)
# Used to upload item metadata and photos
VITE_PINATA_JWT=your_pinata_jwt_here

# ── Foundry deploy vars (NOT prefixed with VITE — these are for forge scripts) ─
# Get a free Sepolia RPC from https://infura.io or https://alchemy.com
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your_key_here

# Your wallet private key for deployment (use a throwaway dev wallet only)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Etherscan API key for contract verification (free at https://etherscan.io)
ETHERSCAN_API_KEY=your_etherscan_key_here
